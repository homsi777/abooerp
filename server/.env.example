NODE_ENV=development
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=replace_with_strong_password
PGSSL_ENABLED=false
PGSSL_REJECT_UNAUTHORIZED=true
ALLOW_DB_SEED=false
# مسح السندات والحركات المالية: npm run server:clean-transactional مع
# ALLOW_TRANSACTIONAL_CLEAN=true
# مسح كامل للبيانات وترك admin فقط: npm run server:wipe-bare مع
# ALLOW_BARE_WIPE=true
# (في production أضف أيضاً ALLOW_BARE_WIPE_IN_PROD=true عند الضرورة)
# في التطوير يُستمد المنفذ من `config/dev-ports.json` ما لم تضبط LOCK_SERVER_PORT=1
LOCK_SERVER_PORT=
SERVER_PORT=4010
AUTH_JWT_SECRET=replace_with_very_long_random_secret_value_min_32_chars
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_STRICT_RBAC=true
DASHBOARD_CACHE_TTL_MS=15000
DASHBOARD_CACHE_RESET_ENABLED=true
DASHBOARD_CACHE_RESET_REQUIRE_CONFIRM=false
# Comma-separated browser origins allowed by CORS and Web/VPS login bypass.
# Example: http://65.21.136.217:2730,https://abooerp.com,http://abooerp.com
WEB_PUBLIC_ORIGINS=
WEB_MODE_ENABLED=false
# Backward-compatible alias. Prefer WEB_MODE_ENABLED for new deployments.
DISABLE_DEVICE_AUTH_FOR_WEB=false
# Native Android agent app: send X-Client-Type: mobile. No fake machineId required.
MOBILE_MODE_ENABLED=false
